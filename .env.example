# Depth Clash - Environment Configuration

# Development Server URL
# Used for local development (desktop)
# The backend Socket.io server should be running on this URL
VITE_SERVER_URL=http://localhost:4000

# Gemini API Key (optional)
# Required only if using Gemini AI features
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# App URL (optional)
# Used for self-referential links and OAuth callbacks
APP_URL="http://localhost:3000"

# Copy to .env.android for Android builds with your local IP:
# VITE_SERVER_URL=http://192.168.0.104:4000
# (Replace 192.168.0.104 with your machine's IP: hostname -I)

